# Study Time Tracker — mobile environment template.
# Copy to `.env` and adjust for your local setup, then pass it to Flutter via:
#
#   flutter run --dart-define-from-file=.env
#   flutter build apk --dart-define-from-file=.env
#
# Flutter reads simple KEY=value pairs from this file at build time and exposes
# each key via `String.fromEnvironment('KEY')`. No `flutter_dotenv` package is
# required.
#
# If you omit --dart-define-from-file entirely, constants.dart falls back to
# sensible per-platform defaults (10.0.2.2 on Android, localhost elsewhere).

# Backend base URL (Express + TypeORM API, mounted at /api/v1).
# Examples:
#   iOS simulator + desktop  http://localhost:3000/api/v1
#   Android emulator         http://10.0.2.2:3000/api/v1
#   Physical device + ngrok  https://<your-id>.ngrok-free.dev/api/v1
#   Staging                  https://api.staging.example.com/api/v1
API_BASE_URL=http://localhost:3000/api/v1
