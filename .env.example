# Compose interpolation for docker-compose.yml.
# Copy to .env (gitignored) and override for your local stack.
#
# When running the backend natively (`cd backend && npm run dev`), point
# backend/.env at:
#   DB_HOST=localhost
#   DB_PORT=3307
#   DB_USERNAME=$MYSQL_USER
#   DB_PASSWORD=$MYSQL_PASSWORD
#   DB_DATABASE=$MYSQL_DATABASE
#
# If a `backend` service is later added to this compose file, the backend
# container should instead use DB_HOST=mysql, DB_PORT=3306 (the compose
# service name and the container-internal port — host port mapping only
# matters for connections from the host).

MYSQL_ROOT_PASSWORD=rootpw_dev_only
MYSQL_DATABASE=timetracker
MYSQL_USER=timetracker
MYSQL_PASSWORD=change_me_dev
